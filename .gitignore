# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
elixir_tak-*.tar

# Temporary files, for example, from tests.
/tmp/

# Generated TLS certificates.
/certs/

# SQLite database files.
/data/*.db
/data/*.db-*

# Runtime-generated data files.
/data/server_uid
/data/dashboard_uid
/data/packages/

# Node dependencies.
/assets/node_modules/

# TypeScript incremental build cache.
/assets/tsconfig.tsbuildinfo

# Vite build output (regenerated by `mix dashboard.build`).
/priv/static/dashboard/

# LLM-related files, which may contain sensitive information
/.claude
CLAUDE.md